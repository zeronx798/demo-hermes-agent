# ============================================================================
# Hermes Agent — 环境变量模板（.env.example）
# ----------------------------------------------------------------------------
# 这是「随源码走」的模板，只列出键名、不含任何真实密钥。
# 部署到新机器后：复制本文件为同目录下的 .env，再填入你自己的密钥。
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
# 真实的 .env 已被 .gitignore 排除，永远不会进入版本库 / 打包。
# 完整变量参考见 website/docs/reference/environment-variables.md
# ============================================================================

# --- 网关 / 访问控制 ---
# 是否允许所有用户（无 allowlist）。本机默认开启；对外部署请按需收紧。
GATEWAY_ALLOW_ALL_USERS=true

# --- LLM 提供商 ---
# 【当前默认】MiniMax Coding Plan（模型 MiniMax-M2.7-highspeed，见 config.yaml）
#   只需提供 API key；base_url 已在 config.yaml 固定为国内端点 api.minimaxi.com。
#   注意：本机把 key 放在「系统/用户环境变量」MINIMAX_API_KEY 中（非本文件）。
#   部署到新机器时，二选一：① 设系统环境变量 MINIMAX_API_KEY；② 在 .env 里取消下一行注释并填值。
#MINIMAX_API_KEY=
# 如需改用全球端点，在 config.yaml 把 base_url 改为 https://api.minimax.io/anthropic

# 其他可选 provider（取消注释并填值即可切换）
#OPENROUTER_API_KEY=
#OPENAI_API_KEY=
#OPENAI_BASE_URL=
#ANTHROPIC_API_KEY=
#GLM_API_KEY=
#KIMI_API_KEY=
#DEEPSEEK_API_KEY=

# --- 工具类 API（按需）---
# 网页搜索 / 抓取
#TAVILY_API_KEY=
#FIRECRAWL_API_KEY=
# 图片生成
#FAL_KEY=

# --- 消息网关（仅当用 gateway 时；这些是高危凭据，切勿提交）---
#TELEGRAM_BOT_TOKEN=
#TELEGRAM_ALLOWED_USERS=
#DISCORD_BOT_TOKEN=
#SLACK_BOT_TOKEN=

# --- 可选：固定运行模型 ---
#HERMES_MODEL=
